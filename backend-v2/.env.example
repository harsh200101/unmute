# Copy to .env and fill in. .env is gitignored.

# --- Server ---
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# --- Database ---
# Phase 0 uses a brand new database alongside the current one.
# Default local: postgres://postgres:postgres@localhost:5432/unmute_v2
DATABASE_URL=postgres://postgres:postgres@localhost:5432/unmute_v2

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Admin seed (optional) ---
# If both are set, `npm run seed` upserts an admin user with these credentials.
# Leave empty in production and create admins via SQL instead.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# --- Google OAuth (phase 1; can stay empty until then) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# --- Email (phase 1; provider to be decided in §8 open questions) ---
EMAIL_FROM=no-reply@unmute.local
EMAIL_PROVIDER=stub
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Frontend origin (CORS) ---
FRONTEND_URL=http://localhost:5173

# --- PhonePe ---
# Defaults are PhonePe's public UAT sandbox — usable for local dev.
# In production, replace with the merchant credentials from your PhonePe dashboard.
PHONEPE_MERCHANT_ID=PGTESTPAYUAT86
PHONEPE_SALT_KEY=96434309-7796-489d-8924-ab56988a6076
PHONEPE_SALT_INDEX=1
PHONEPE_HOST=https://api-preprod.phonepe.com/apis/pg-sandbox
# Production PhonePe host: https://api.phonepe.com/apis/hermes

# --- Agora ---
# Get from https://console.agora.io → your project → "App Certificate"
# Without these, the meeting room runs in stub mode (no real video).
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
