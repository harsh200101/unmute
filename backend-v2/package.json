{
  "name": "unmute-backend-v2",
  "version": "0.1.0",
  "private": true,
  "description": "unmute v2 backend — see ../docs/v2-spec.md",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/migrator.js up",
    "migrate:status": "node src/migrator.js status",
    "seed": "node src/seed.js",
    "dev:seed": "node src/dev-seed.js",
    "db:reset": "node src/migrator.js reset && npm run migrate && npm run seed",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src"
  },
  "dependencies": {
    "agora-token": "^2.0.5",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
